<div class="max-w-7xl mx-auto flex flex-col gap-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-xl font-bold text-slate-900">Riwayat Pesan</h1>
            <p class="text-sm text-slate-500">Daftar pesan yang telah dikirim</p>
        </div>
        <button onclick="deleteAllHistory()" class="py-2 px-4 bg-red-500 hover:bg-red-600 text-white rounded-lg font-medium text-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">delete_sweep</span>
            Hapus Semua
        </button>
    </div>

    <!-- History Table -->
    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50 border-b border-slate-200">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">No</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Session</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Tipe</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Tujuan</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Pesan</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Waktu</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-slate-600 uppercase">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <% if (db && db.length > 0) { %>
                        <% db.forEach((item, index) => { %>
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 py-3 text-sm text-slate-600"><%= index + 1 %></td>
                            <td class="px-4 py-3">
                                <span class="px-2 py-1 bg-wa-green/10 text-wa-dark text-xs font-medium rounded-full"><%= item.session_name %></span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="px-2 py-1 bg-blue-100 text-blue-700 text-xs font-medium rounded-full"><%= item.type %></span>
                            </td>
                            <td class="px-4 py-3 text-sm text-slate-900 font-mono"><%= item.target %></td>
                            <td class="px-4 py-3 text-sm text-slate-600 max-w-xs truncate"><%= item.message %></td>
                            <td class="px-4 py-3 text-sm text-slate-500"><%= item.createdAt %></td>
                            <td class="px-4 py-3 text-center">
                                <button onclick="deleteHistory('<%= item.id %>')" class="p-1.5 text-red-500 hover:bg-red-50 rounded-lg">
                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                </button>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                    <tr>
                        <td colspan="7" class="px-4 py-12 text-center">
                            <div class="flex flex-col items-center">
                                <span class="material-symbols-outlined text-5xl text-slate-300 mb-3">inbox</span>
                                <p class="text-slate-500">Belum ada riwayat pesan</p>
                            </div>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
async function deleteHistory(id) {
    const result = await Swal.fire({
        title: 'Hapus Riwayat?',
        text: 'Data akan dihapus permanen',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Ya, Hapus!',
        cancelButtonText: 'Batal'
    });
    
    if (result.isConfirmed) {
        const res = await fetch(`/api/del-history?id=${id}`).then(r => r.json());
        if (res.status == 200) {
            Swal.fire('Berhasil!', 'Riwayat dihapus', 'success').then(() => location.reload());
        } else {
            Swal.fire('Gagal', res.message, 'error');
        }
    }
}

async function deleteAllHistory() {
    const result = await Swal.fire({
        title: 'Hapus Semua Riwayat?',
        text: 'Semua data akan dihapus permanen',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Ya, Hapus Semua!',
        cancelButtonText: 'Batal'
    });
    
    if (result.isConfirmed) {
        const res = await fetch('/api/delall-history').then(r => r.json());
        if (res.status == 200) {
            Swal.fire('Berhasil!', 'Semua riwayat dihapus', 'success').then(() => location.reload());
        } else {
            Swal.fire('Gagal', res.message, 'error');
        }
    }
}
</script>
