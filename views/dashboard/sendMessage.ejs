                <span class="material-symbols-outlined text-purple-600">settings</span>
            </div>
            <div>
                <h3 class="font-semibold text-slate-900">Metode Pengiriman</h3>
                <p class="text-xs text-slate-500">Pilih metode untuk Kirim ke Saluran</p>
