            </div>
            <div class="p-4">
                <button onclick="alertSendNewsletter()" class="w-full py-2.5 px-4 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium text-sm flex items-center justify-center gap-2">
