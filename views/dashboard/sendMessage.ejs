            <button onclick="toggleChannelMethod('whatsapp-web')" id="method-whatsapp-web" class="py-2 px-3 bg-indigo-100 text-indigo-700 rounded-lg font-medium text-sm border border-indigo-200 hover:bg-indigo-200 transition-colors">WhatsApp-web.js</button>
