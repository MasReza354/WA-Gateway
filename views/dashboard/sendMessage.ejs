<script>
    // Set brand value for inputs
    document.addEventListener('DOMContentLoaded', () => {
        const observer = new MutationObserver(() => {
            document.querySelectorAll('._brand_input').forEach(el => {
                if (!el.value) el.value = window._author ? window._author() : '';
            });
        });
        observer.observe(document.body, { childList: true, subtree: true });
    });

    // Channel method toggle
    let selectedChannelMethod = 'whatsapp-web'; // Default

    function toggleChannelMethod(method) {
        selectedChannelMethod = method;
        
        // Update button states
        document.getElementById('method-whatsapp-web').className = 
            method === 'whatsapp-web' ? 
            'py-2 px-3 bg-indigo-100 text-indigo-700 rounded-lg font-medium text-sm border border-indigo-200 hover:bg-indigo-200 transition-colors' :
            'py-2 px-3 bg-gray-100 text-gray-600 rounded-lg font-medium text-sm border border-gray-200 hover:bg-gray-200 transition-colors';
        
        document.getElementById('method-baileys').className = 
            method === 'baileys' ? 
            'py-2 px-3 bg-indigo-100 text-indigo-700 rounded-lg font-medium text-sm border border-indigo-200 hover:bg-indigo-200 transition-colors' :
            'py-2 px-3 bg-gray-100 text-gray-600 rounded-lg font-medium text-sm border border-gray-200 hover:bg-gray-200 transition-colors';
        
        // Update status
        document.getElementById('channel-method-status').textContent = 
            method === 'whatsapp-web' ? 'WhatsApp-web.js (aktif)' : 'Baileys (aktif)';
    }

    async function alertSendNewsletter() {
    const { value: formValues } = await Swal.fire({
        title: '<span class="material-symbols-outlined text-indigo-600 align-middle">broadcast_on_home</span> Kirim ke Saluran',
        html: `
            <div class="text-left space-y-3">
                <div class="p-3 bg-amber-50 border border-amber-200 rounded-lg">
                    <p class="text-xs text-amber-700"><strong>Info:</strong> Anda harus menjadi <strong>ADMIN</strong> channel untuk mengirim pesan. Hanya TEXT yang didukung.</p>
                    <p class="text-xs text-amber-700 mt-1"><strong>Metode:</strong> ${selectedChannelMethod === 'whatsapp-web' ? 'WhatsApp-web.js' : 'Baileys'}</p>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Session</label>
                    <select id="swal-session" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm">
                        <% if (Array.isArray(session) && session.length) { session.forEach((el) => { %>
                        <option value="<%= el.session_name %>"><%= el.session_name %> (+<%= el.session_number %>)</option>
                        <% }); } %>
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Channel ID</label>
                    <input id="swal-channel" type="text" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="120363285413560907">
                    <p class="text-xs text-slate-400 mt-1">Format: 120363xxxx (tanpa @newsletter)</p>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Pesan</label>
                    <textarea id="swal-message" rows="3" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="Tulis pesan untuk channel..."></textarea>
                </div>
                <div class="text-xs text-slate-500">
                    <strong>Metode saat ini:</strong> ${selectedChannelMethod === 'whatsapp-web' ? 'WhatsApp-web.js (membutuhkan QR scan sekali)' : 'Baileys (metode lama)'}
                </div>
            </div>
        `,
        showCancelButton: true,
        confirmButtonColor: '#4f46e5',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Kirim ke Saluran',
        cancelButtonText: 'Batal',
        preConfirm: () => {
            const session = document.getElementById('swal-session').value;
            const channelId = document.getElementById('swal-channel').value;
            const message = document.getElementById('swal-message').value;
            
            if (!channelId) {
                Swal.showValidationMessage('Channel ID wajib diisi!');
                return false;
            }
            if (!message) {
                Swal.showValidationMessage('Pesan wajib diisi!');
                return false;
            }
            
            return { 
                sessions: session, 
                channelId, 
                message,
                method: selectedChannelMethod
            };
        }
    });

    if (formValues) {
        Swal.fire({
            title: 'Mengirim...',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });
        
        const res = await fetch('/api/sendnewsletter', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formValues)
        }).then(r => r.json());
        
        if (res.status == 200) {
            Swal.fire('Berhasil!', res.message, 'success');
        } else {
            Swal.fire('Gagal', res.message + (res.tip ? '<br><br><small>' + res.tip + '</small>' : ''), 'error');
        }
    }
}

function useTemplate(text) {
    alertSendText(text);
}

async function alertSendText(prefillMessage = '') {
    const { value: formValues } = await Swal.fire({
        title: '<span class="material-symbols-outlined text-blue-600 align-middle">chat</span> Kirim Teks',
        html: `
            <div class="text-left space-y-3">
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Session</label>
                    <select id="swal-session" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm">
                        <% if (Array.isArray(session) && session.length) { session.forEach((el) => { %>
                        <option value="<%= el.session_name %>"><%= el.session_name %> (+<%= el.session_number %>)</option>
                        <% }); } %>
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Nomor Tujuan</label>
                    <input id="swal-target" type="text" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="628123456789">
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Pesan</label>
                    <textarea id="swal-message" rows="3" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="Tulis pesan...">${prefillMessage}</textarea>
                </div>
            </div>
        `,
        showCancelButton: true,
        confirmButtonColor: '#2563eb',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Kirim',
        cancelButtonText: 'Batal',
        preConfirm: () => {
            return {
                sessions: document.getElementById('swal-session').value,
                target: document.getElementById('swal-target').value,
                message: document.getElementById('swal-message').value
            }
        }
    });

    if (formValues) {
        const res = await fetch('/api/sendtext', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formValues)
        }).then(r => r.json());
        
        if (res.status == 200) {
            Swal.fire('Berhasil!', res.message, 'success');
        } else {
            Swal.fire('Gagal', res.message, 'error');
        }
    }
}

async function alertSendMedia() {
    const { value: formValues } = await Swal.fire({
        title: '<span class="material-symbols-outlined text-purple-600 align-middle">image</span> Kirim Media',
        html: `
            <div class="text-left space-y-3">
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Session</label>
                    <select id="swal-session" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm">
                        <% if (Array.isArray(session) && session.length) { session.forEach((el) => { %>
                        <option value="<%= el.session_name %>"><%= el.session_name %></option>
                        <% }); } %>
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Nomor Tujuan</label>
                    <input id="swal-target" type="text" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="628123456789">
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">File</label>
                    <input id="swal-file" type="file" class="w-full text-sm">
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Atau URL</label>
                    <input id="swal-url" type="text" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="https://...">
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Caption</label>
                    <textarea id="swal-message" rows="2" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="Caption (opsional)"></textarea>
                </div>
            </div>
        `,
        showCancelButton: true,
        confirmButtonColor: '#9333ea',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Kirim',
        cancelButtonText: 'Batal',
        preConfirm: () => {
            const file = document.getElementById('swal-file').files[0];
            return { file, sessions: document.getElementById('swal-session').value, target: document.getElementById('swal-target').value, url: document.getElementById('swal-url').value, message: document.getElementById('swal-message').value };
        }
    });

    if (formValues) {
        let body, headers = {};
        if (formValues.file) {
            body = new FormData();
            body.append('file', formValues.file);
            body.append('sessions', formValues.sessions);
            body.append('target', formValues.target);
            body.append('message', formValues.message);
        } else {
            headers = { 'Content-Type': 'application/json' };
            body = JSON.stringify(formValues);
        }
        
        const res = await fetch('/api/sendmedia', { method: 'POST', headers, body }).then(r => r.json());
        if (res.status == 200) Swal.fire('Berhasil!', res.message, 'success');
        else Swal.fire('Gagal', res.message, 'error');
    }
}

