async function alertSendBulk() {
    const { value: formValues } = await Swal.fire({
        title: '<span class="material-symbols-outlined text-teal-600 align-middle">groups</span> Kirim Massal',
        html: `
            <div class="text-left space-y-3">
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Session</label>
                    <select id="swal-session" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm">
                        <% if (Array.isArray(session) && session.length) { session.forEach((el) => { %>
                        <option value="<%= el.session_name %>"><%= el.session_name %></option>
                        <% }); } %>
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Nomor Tujuan (pisahkan dengan koma atau enter)</label>
                    <textarea id="swal-targets" rows="4" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm font-mono" placeholder="628123456789&#10;628987654321&#10;628111222333"></textarea>
                    <p class="text-xs text-slate-400 mt-1">Contoh: 628123456789, 628987654321</p>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Pesan</label>
                    <textarea id="swal-message" rows="3" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="Tulis pesan broadcast..."></textarea>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Delay antar pesan (detik)</label>
                    <input id="swal-delay" type="number" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" value="3" min="1" max="60">
                    <p class="text-xs text-slate-400 mt-1">Rekomendasi: 3-5 detik untuk menghindari ban</p>
                </div>
            </div>
        `,
        showCancelButton: true,
        confirmButtonColor: '#0d9488',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Kirim Broadcast',
        cancelButtonText: 'Batal',
        preConfirm: () => ({
            sessions: document.getElementById('swal-session').value,
            targets: document.getElementById('swal-targets').value,
            message: document.getElementById('swal-message').value,
            delay: parseInt(document.getElementById('swal-delay').value) || 3
        })
    });

    if (formValues && formValues.targets && formValues.message) {
        // Parse targets (split by comma, newline, or space)
        const targets = formValues.targets.split(/[,\n\s]+/).map(t => t.trim()).filter(t => t.length > 0);
        
        if (targets.length === 0) {
            return Swal.fire('Error', 'Masukkan minimal 1 nomor tujuan', 'error');
        }

        Swal.fire({
            title: 'Mengirim Broadcast...',
            html: `<div id="bulk-progress">0 / ${targets.length} terkirim</div>`,
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        let success = 0, failed = 0;
        for (let i = 0; i < targets.length; i++) {
            try {
                const res = await fetch('/api/sendtext', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        sessions: formValues.sessions,
                        target: targets[i],
                        message: formValues.message
                    })
                }).then(r => r.json());
                
                if (res.status == 200) success++;
                else failed++;
            } catch (e) {
                failed++;
            }
            
            document.getElementById('bulk-progress').innerHTML = `${i + 1} / ${targets.length} terkirim<br><span class="text-green-600">${success} berhasil</span> | <span class="text-red-600">${failed} gagal</span>`;
            
            // Delay between messages
            if (i < targets.length - 1) {
                await new Promise(r => setTimeout(r, formValues.delay * 1000));
            }
        }

        Swal.fire({
            title: 'Broadcast Selesai!',
            html: `<div class="text-center"><p class="text-green-600 font-bold text-2xl">${success}</p><p class="text-sm text-slate-500">Berhasil terkirim</p><p class="text-red-600 font-bold text-2xl mt-2">${failed}</p><p class="text-sm text-slate-500">Gagal</p></div>`,
            icon: failed === 0 ? 'success' : 'warning'
        });
    }
}

async function alertSendNewsletter() {
    const { value: formValues } = await Swal.fire({
        title: '<span class="material-symbols-outlined text-indigo-600 align-middle">broadcast_on_home</span> Kirim ke Saluran',
        html: `
            <div class="text-left space-y-3">
                <div class="p-3 bg-amber-50 border border-amber-200 rounded-lg">
                    <p class="text-xs text-amber-700"><strong>Info:</strong> Anda harus menjadi <strong>ADMIN</strong> channel untuk mengirim pesan. Hanya TEXT yang didukung.</p>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Session</label>
                    <select id="swal-session" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm">
                        <% if (Array.isArray(session) && session.length) { session.forEach((el) => { %>
                        <option value="<%= el.session_name %>"><%= el.session_name %> (+<%= el.session_number %>)</option>
                        <% }); } %>
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Channel ID</label>
                    <input id="swal-channel" type="text" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="120363285413560907">
                    <p class="text-xs text-slate-400 mt-1">Format: 120363xxxx (tanpa @newsletter)</p>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Pesan</label>
                    <textarea id="swal-message" rows="3" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="Tulis pesan untuk channel..."></textarea>
                </div>
            </div>
        `,
        showCancelButton: true,
        confirmButtonColor: '#4f46e5',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Kirim ke Saluran',
        cancelButtonText: 'Batal',
        preConfirm: () => {
            const session = document.getElementById('swal-session').value;
            const channelId = document.getElementById('swal-channel').value;
            const message = document.getElementById('swal-message').value;
            
            if (!channelId) {
                Swal.showValidationMessage('Channel ID wajib diisi!');
                return false;
            }
            if (!message) {
                Swal.showValidationMessage('Pesan wajib diisi!');
                return false;
            }
            
            return { sessions: session, channelId, message };
        }
    });

    if (formValues) {
        Swal.fire({
            title: 'Mengirim...',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });
        
        const res = await fetch('/api/sendnewsletter', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formValues)
        }).then(r => r.json());
        
        if (res.status == 200) {
            Swal.fire('Berhasil!', res.message, 'success');
        } else {
            Swal.fire('Gagal', res.message + (res.tip ? '<br><br><small>' + res.tip + '</small>' : ''), 'error');
        }
    }
}



// Set brand value for inputs
document.addEventListener('DOMContentLoaded', () => {
    const observer = new MutationObserver(() => {
        document.querySelectorAll('._brand_input').forEach(el => {
            if (!el.value) el.value = window._author ? window._author() : '';
        });
    });
    observer.observe(document.body, { childList: true, subtree: true });
});
</script>
