<div class="max-w-7xl mx-auto flex flex-col gap-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-xl font-bold text-slate-900">Jadwal Pesan</h1>
            <p class="text-sm text-slate-500">Atur pengiriman pesan otomatis di waktu tertentu</p>
        </div>
        <button onclick="addScheduledMessage()" class="py-2 px-4 bg-wa-green hover:bg-wa-teal text-white rounded-lg font-medium text-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">schedule_send</span>
            Jadwalkan Pesan
        </button>
    </div>

    <!-- Info Card -->
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
        <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-amber-600">info</span>
            <div>
                <p class="text-sm font-medium text-amber-800">Cara Kerja Jadwal Pesan</p>
                <p class="text-xs text-amber-700 mt-1">Pesan akan dikirim otomatis sesuai waktu yang ditentukan. Pastikan session WhatsApp tetap aktif.</p>
            </div>
        </div>
    </div>

    <!-- Scheduled Messages List -->
    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50 border-b border-slate-200">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">No</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Session</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Tujuan</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Pesan</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Jadwal</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Status</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-slate-600 uppercase">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <% if (scheduled && scheduled.length > 0) { %>
                        <% scheduled.forEach((item, index) => { %>
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 py-3 text-sm text-slate-600"><%= index + 1 %></td>
                            <td class="px-4 py-3">
                                <span class="px-2 py-1 bg-wa-green/10 text-wa-dark text-xs font-medium rounded-full"><%= item.session_name %></span>
                            </td>
                            <td class="px-4 py-3 text-sm text-slate-900 font-mono"><%= item.target %></td>
                            <td class="px-4 py-3 text-sm text-slate-600 max-w-xs truncate"><%= item.message %></td>
                            <td class="px-4 py-3 text-sm text-slate-600">
                                <%= new Date(item.scheduled_at).toLocaleString('id-ID') %>
                            </td>
                            <td class="px-4 py-3">
                                <% if (item.status === 'pending') { %>
                                <span class="px-2 py-1 bg-yellow-100 text-yellow-700 text-xs font-medium rounded-full">Menunggu</span>
                                <% } else if (item.status === 'sent') { %>
                                <span class="px-2 py-1 bg-green-100 text-green-700 text-xs font-medium rounded-full">Terkirim</span>
                                <% } else if (item.status === 'failed') { %>
                                <span class="px-2 py-1 bg-red-100 text-red-700 text-xs font-medium rounded-full">Gagal</span>
                                <% } else { %>
                                <span class="px-2 py-1 bg-slate-100 text-slate-700 text-xs font-medium rounded-full">Dibatalkan</span>
                                <% } %>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <% if (item.status === 'pending') { %>
                                <button onclick="cancelScheduled('<%= item.id %>')" class="p-1.5 text-red-500 hover:bg-red-50 rounded-lg" title="Batalkan">
                                    <span class="material-symbols-outlined text-[18px]">cancel</span>
                                </button>
                                <% } %>
                                <button onclick="deleteScheduled('<%= item.id %>')" class="p-1.5 text-slate-500 hover:bg-slate-50 rounded-lg" title="Hapus">
                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                </button>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                    <tr>
                        <td colspan="7" class="px-4 py-12 text-center">
                            <div class="flex flex-col items-center">
                                <span class="material-symbols-outlined text-5xl text-slate-300 mb-3">schedule</span>
                                <p class="text-slate-500">Belum ada jadwal pesan</p>
                                <p class="text-xs text-slate-400 mt-1">Klik "Jadwalkan Pesan" untuk membuat</p>
                            </div>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
async function addScheduledMessage() {
    // Get current datetime + 1 hour as default
    const now = new Date();
    now.setHours(now.getHours() + 1);
    const defaultDateTime = now.toISOString().slice(0, 16);

    const { value: formValues } = await Swal.fire({
        title: '<span class="material-symbols-outlined text-wa-green align-middle">schedule_send</span> Jadwalkan Pesan',
        html: `
            <div class="text-left space-y-3">
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Session</label>
                    <select id="swal-session" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm">
                        <% if (Array.isArray(sessions) && sessions.length) { sessions.forEach((el) => { %>
                        <option value="<%= el.session_name %>"><%= el.session_name %> (<%= el.session_number || '-' %>)</option>
                        <% }); } %>
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Nomor Tujuan</label>
                    <input id="swal-target" type="text" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="628123456789">
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Pesan</label>
                    <textarea id="swal-message" rows="3" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" placeholder="Tulis pesan..."></textarea>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700 mb-1 block">Waktu Kirim</label>
                    <input id="swal-datetime" type="datetime-local" class="w-full rounded-lg border border-slate-200 py-2 px-3 text-sm" value="${defaultDateTime}">
                </div>
            </div>
        `,
        showCancelButton: true,
        confirmButtonColor: '#25D366',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Jadwalkan',
        cancelButtonText: 'Batal',
        preConfirm: () => ({
            session_name: document.getElementById('swal-session').value,
            target: document.getElementById('swal-target').value,
            message: document.getElementById('swal-message').value,
            scheduled_at: document.getElementById('swal-datetime').value
        })
    });

    if (formValues && formValues.target && formValues.message && formValues.scheduled_at) {
        const res = await fetch('/api/schedule/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formValues)
        }).then(r => r.json());
        
        if (res.status == 200) {
            Swal.fire('Berhasil!', 'Pesan dijadwalkan', 'success').then(() => location.reload());
        } else {
            Swal.fire('Gagal', res.message, 'error');
        }
    }
}

async function cancelScheduled(id) {
    const result = await Swal.fire({
        title: 'Batalkan Jadwal?',
        text: 'Pesan tidak akan dikirim',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#eab308',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Ya, Batalkan!',
        cancelButtonText: 'Tidak'
    });
    
    if (result.isConfirmed) {
        const res = await fetch(`/api/schedule/cancel?id=${id}`).then(r => r.json());
        if (res.status == 200) {
            Swal.fire('Berhasil!', 'Jadwal dibatalkan', 'success').then(() => location.reload());
        } else {
            Swal.fire('Gagal', res.message, 'error');
        }
    }
}

async function deleteScheduled(id) {
    const result = await Swal.fire({
        title: 'Hapus Jadwal?',
        text: 'Data akan dihapus permanen',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Ya, Hapus!',
        cancelButtonText: 'Batal'
    });
    
    if (result.isConfirmed) {
        const res = await fetch(`/api/schedule/delete?id=${id}`).then(r => r.json());
        if (res.status == 200) {
            Swal.fire('Berhasil!', 'Jadwal dihapus', 'success').then(() => location.reload());
        } else {
            Swal.fire('Gagal', res.message, 'error');
        }
    }
}
</script>
