<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WA Gateway</title>
    <link rel="shortcut icon" href="/assets/images/logo/favicon.png" type="image/png" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.socket.io/4.4.1/socket.io.min.js" crossorigin="anonymous"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { 
                        "primary": "#25D366",
                        "primary-dark": "#128C7E", 
                        "background": "#f0f2f5",
                        "wa-green": "#25D366",
                        "wa-teal": "#128C7E",
                        "wa-dark": "#075E54"
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Lexend', sans-serif; }
        .sidebar-link.active { background: linear-gradient(135deg, #25D366 0%, #128C7E 100%); color: white; }
        .sidebar-link:hover:not(.active) { background: #f0f2f5; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #a1a1a1; }
    </style>
    <script>
        (function(){var _0x=[77,97,115,32,82,101,122,97];var _0xg=function(){return String.fromCharCode.apply(null,_0x)};window._author=_0xg;setInterval(function(){if(typeof window._author!=='function'){window._author=_0xg}document.querySelectorAll('._brand').forEach(function(e){if(e.textContent!==_0xg())e.textContent=_0xg()});if(!document.title.includes(_0xg()))document.title='WA Gateway - '+_0xg()},500)})();
    </script>
</head>
<body class="font-display bg-background text-slate-900 overflow-hidden antialiased">
<div class="flex h-screen w-full">
    <!-- Sidebar -->
    <aside id="sidebar" class="hidden lg:flex flex-col w-64 bg-white border-r border-slate-200 transition-all duration-300">
        <div class="p-5 border-b border-slate-100">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-wa-green to-wa-teal flex items-center justify-center">
                    <i class="fab fa-whatsapp text-white text-xl"></i>
                </div>
                <div>
                    <h1 class="font-bold text-slate-900">WA Gateway</h1>
                    <p class="text-xs text-slate-500">by <span class="_brand"></span></p>
                </div>
            </div>
        </div>
        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3 px-3">Menu</p>
            <a href="/dashboard" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">dashboard</span>
                Dashboard
            </a>
            <a href="/dashboard/send-message" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/send-message' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">send</span>
                Kirim Pesan
            </a>
            <a href="/dashboard/scheduled" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/scheduled' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">schedule_send</span>
                Jadwal Pesan
            </a>
            <a href="/dashboard/history-message" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/history-message' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">history</span>
                Riwayat Pesan
            </a>
            <a href="/dashboard/auto-reply" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/auto-reply' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">smart_toy</span>
                Auto Reply
            </a>
            <a href="/dashboard/sessions" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/sessions' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">smartphone</span>
                Kelola Session
            </a>
            <a href="/dashboard/channels" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/channels' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">broadcast_on_home</span>
                Kelola Saluran
            </a>
            <a href="/dashboard/api-doc" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/api-doc' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">api</span>
                API Docs
            </a>
        </nav>
        <div class="p-4 border-t border-slate-100">
            <div class="flex items-center gap-3 mb-3 px-3">
                <div class="w-8 h-8 rounded-full bg-wa-green/20 flex items-center justify-center">
                    <span class="material-symbols-outlined text-wa-dark text-[18px]">person</span>
                </div>
                <span class="text-sm font-medium text-slate-700">Administrator</span>
            </div>
            <a href="/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50 transition-all">
                <span class="material-symbols-outlined text-[20px]">logout</span>
                Logout
            </a>
        </div>
    </aside>

    <!-- Mobile Sidebar Overlay -->
    <div id="sidebar-overlay" class="hidden fixed inset-0 bg-black/50 z-40 lg:hidden" onclick="toggleSidebar()"></div>
    
    <!-- Mobile Sidebar -->
    <aside id="mobile-sidebar" class="fixed left-0 top-0 h-full w-64 bg-white border-r border-slate-200 z-50 transform -translate-x-full transition-transform duration-300 lg:hidden">
        <div class="p-5 border-b border-slate-100 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-wa-green to-wa-teal flex items-center justify-center">
                    <i class="fab fa-whatsapp text-white text-xl"></i>
                </div>
                <div>
                    <h1 class="font-bold text-slate-900">WA Gateway</h1>
                    <p class="text-xs text-slate-500">by <span class="_brand"></span></p>
                </div>
            </div>
            <button onclick="toggleSidebar()" class="p-1 text-slate-400 hover:text-slate-600">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <nav class="p-4 space-y-1">
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3 px-3">Menu</p>
            <a href="/dashboard" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">dashboard</span>
                Dashboard
            </a>
            <a href="/dashboard/send-message" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/send-message' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">send</span>
                Kirim Pesan
            </a>
            <a href="/dashboard/scheduled" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/scheduled' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">schedule_send</span>
                Jadwal Pesan
            </a>
            <a href="/dashboard/history-message" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/history-message' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">history</span>
                Riwayat Pesan
            </a>
            <a href="/dashboard/auto-reply" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/auto-reply' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">smart_toy</span>
                Auto Reply
            </a>
            <a href="/dashboard/sessions" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/sessions' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">smartphone</span>
                Kelola Session
            </a>
            <a href="/dashboard/api-doc" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-700 transition-all <%= url == '/dashboard/api-doc' ? 'active' : '' %>">
                <span class="material-symbols-outlined text-[20px]">api</span>
                API Docs
            </a>
            <div class="border-t border-slate-100 mt-4 pt-4">
                <div class="flex items-center gap-3 mb-3 px-3">
                    <div class="w-8 h-8 rounded-full bg-wa-green/20 flex items-center justify-center">
                        <span class="material-symbols-outlined text-wa-dark text-[18px]">person</span>
                    </div>
                    <span class="text-sm font-medium text-slate-700">Administrator</span>
                </div>
                <a href="/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50 transition-all">
                    <span class="material-symbols-outlined text-[20px]">logout</span>
                    Logout
                </a>
            </div>
        </nav>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Header -->
        <header class="flex items-center justify-between border-b border-slate-200 bg-white px-6 py-4">
            <div class="flex items-center gap-4">
                <button class="lg:hidden text-slate-500 hover:text-slate-700" onclick="toggleSidebar()">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                <h2 class="text-lg font-bold text-slate-900">WhatsApp Gateway</h2>
            </div>
            <div class="flex items-center gap-3">
                <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 bg-wa-green/10 rounded-full">
                    <span class="w-2 h-2 rounded-full bg-wa-green animate-pulse"></span>
                    <span class="text-xs font-medium text-wa-dark">Server Active</span>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="flex-1 overflow-y-auto p-4 md:p-6">
            <%- body %>
        </main>

        <!-- Footer -->
        <footer class="border-t border-slate-200 bg-white px-6 py-3">
            <p class="text-xs text-slate-500 text-center">© 2026 <span class="_brand"></span> • WhatsApp Gateway</p>
        </footer>
    </div>
</div>

<script>
function toggleSidebar() {
    const overlay = document.getElementById('sidebar-overlay');
    const sidebar = document.getElementById('mobile-sidebar');
    overlay.classList.toggle('hidden');
    sidebar.classList.toggle('-translate-x-full');
}
// Initialize protected branding
document.addEventListener('DOMContentLoaded',()=>{document.querySelectorAll('._brand').forEach(e=>e.textContent=window._author());document.title='WA Gateway - '+window._author();});
</script>
</body>
</html>
